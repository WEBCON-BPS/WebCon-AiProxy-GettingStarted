# Thin layer on top of the locally-built AI Proxy image that bakes in the
# sandbox aiconfiguration.json (the app requires /app/aiconfiguration.json to exist).
# With UseAzureKeyVault=true this file holds only KV secret NAMES, never real keys,
# so it is safe to bake into the image.
ARG BASE_IMAGE=webconbps/aiproxy:2026.2.64.17
FROM ${BASE_IMAGE}
COPY aiconfiguration.json /app/aiconfiguration.json
